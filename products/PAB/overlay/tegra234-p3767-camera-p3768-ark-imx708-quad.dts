//
// IMX708 (Raspberry Pi / Arducam Camera Module 3) 4-camera overlay for the ARK
// p3768 carrier (4x2-lane CSI). Carrier wiring (TCA9546 mux, per-port CAM reset and
// lane polarity) mirrors the IMX219 quad; sensor nodes and mode0 come from RidgeRun's
// IMX708 driver. One 10-bit mode, 4608x2592 @ ~14 fps, fixed focus.

/dts-v1/;
/plugin/;

#define CAM0_PWDN	TEGRA234_MAIN_GPIO(H, 6)
#define CAM1_PWDN	TEGRA234_MAIN_GPIO(AC, 0)
#define CAM2_PWDN	TEGRA234_MAIN_GPIO(Y, 4)
#define CAM3_PWDN	TEGRA234_AON_GPIO(CC, 3)
#define CAMERA_I2C_MUX_BUS(x) (0x1E + x)

#include <dt-bindings/tegra234-p3767-0000-common.h>

/ {
	overlay-name = "Camera ARK IMX708 Quad";
	jetson-header-name = "Jetson 22pin CSI Connector";
	compatible = JETSON_COMPATIBLE_P3768;

	fragment-camera@0 {
		target-path = "/";
		__overlay__ {
			tegra-capture-vi {
				num-channels = <4>;
				ports {
					#address-cells = <1>;
					#size-cells = <0>;
					port@0 {
						reg = <0>;
						ark_imx708_vi_in0: endpoint {
							port-index = <0>;
							bus-width = <2>;
							remote-endpoint = <&ark_imx708_csi_out0>;
						};
					};
					port@1 {
						reg = <1>;
						ark_imx708_vi_in1: endpoint {
							port-index = <1>;
							bus-width = <2>;
							remote-endpoint = <&ark_imx708_csi_out1>;
						};
					};
					port@2 {
						reg = <2>;
						ark_imx708_vi_in2: endpoint {
							port-index = <2>;
							bus-width = <2>;
							remote-endpoint = <&ark_imx708_csi_out2>;
						};
					};
					port@3 {
						reg = <3>;
						ark_imx708_vi_in3: endpoint {
							port-index = <3>;
							bus-width = <2>;
							remote-endpoint = <&ark_imx708_csi_out3>;
						};
					};
				};
			};
			tegra-camera-platform {
				compatible = "nvidia, tegra-camera-platform";
				num_csi_lanes = <8>;
				max_lane_speed = <2500000>;	/* imx708 pixel clock is 297.6 MHz vs imx219's 182.4 MHz */
				min_bits_per_pixel = <10>;
				vi_peak_byte_per_pixel = <2>;
				vi_bw_margin_pct = <25>;
				max_pixel_rate = <240000>;	/* per-stream ~167 Mpix/s, same as imx219 */
				isp_peak_byte_per_pixel = <5>;
				isp_bw_margin_pct = <25>;
				modules {
					module0 {
						badge = "ark_imx708_bottomleft_IMX708";
						position = "bottomleft";
						orientation = "0";
						drivernode0 {
							pcl_id = "v4l2_sensor";
							sysfs-device-tree = "/sys/firmware/devicetree/base/bus@0/i2c@3180000/tca9546@70/i2c@0/ark_imx708_a@1a";
						};
					};
					module1 {
						badge = "ark_imx708_bottomright_IMX708";
						position = "bottomright";
						orientation = "1";
						drivernode0 {
							pcl_id = "v4l2_sensor";
							sysfs-device-tree = "/sys/firmware/devicetree/base/bus@0/i2c@3180000/tca9546@70/i2c@1/ark_imx708_b@1a";
						};
					};
					module2 {
						badge = "ark_imx708_centerleft_IMX708";
						position = "centerleft";
						orientation = "2";
						drivernode0 {
							pcl_id = "v4l2_sensor";
							sysfs-device-tree = "/sys/firmware/devicetree/base/bus@0/i2c@3180000/tca9546@70/i2c@2/ark_imx708_c@1a";
						};
					};
					module3 {
						badge = "ark_imx708_centerright_IMX708";
						position = "centerright";
						orientation = "3";
						drivernode0 {
							pcl_id = "v4l2_sensor";
							sysfs-device-tree = "/sys/firmware/devicetree/base/bus@0/i2c@3180000/tca9546@70/i2c@3/ark_imx708_d@1a";
						};
					};
				};
			};
			bus@0 {
				host1x@13e00000 {
					nvcsi@15a00000 {
						num-channels = <4>;
						#address-cells = <1>;
						#size-cells = <0>;
						status = "okay";
						channel@0 {
							reg = <0>;
							ports {
								#address-cells = <1>;
								#size-cells = <0>;
								port@0 {
									reg = <0>;
									ark_imx708_csi_in0: endpoint@0 {
										port-index = <0>;
										bus-width = <2>;
										remote-endpoint = <&ark_imx708_out0>;
									};
								};
								port@1 {
									reg = <1>;
									ark_imx708_csi_out0: endpoint@1 {
										remote-endpoint = <&ark_imx708_vi_in0>;
									};
								};
							};
						};
						channel@1 {
							reg = <1>;
							ports {
								#address-cells = <1>;
								#size-cells = <0>;
								port@0 {
									reg = <0>;
									ark_imx708_csi_in1: endpoint@2 {
										port-index = <1>;
										bus-width = <2>;
										remote-endpoint = <&ark_imx708_out1>;
									};
								};
								port@1 {
									reg = <1>;
									ark_imx708_csi_out1: endpoint@3 {
										remote-endpoint = <&ark_imx708_vi_in1>;
									};
								};
							};
						};
						channel@2 {
							reg = <2>;
							ports {
								#address-cells = <1>;
								#size-cells = <0>;
								port@0 {
									reg = <0>;
									ark_imx708_csi_in2: endpoint@4 {
										port-index = <2>;
										bus-width = <2>;
										remote-endpoint = <&ark_imx708_out2>;
									};
								};
								port@1 {
									reg = <1>;
									ark_imx708_csi_out2: endpoint@5 {
										remote-endpoint = <&ark_imx708_vi_in2>;
									};
								};
							};
						};
						channel@3 {
							reg = <3>;
							ports {
								#address-cells = <1>;
								#size-cells = <0>;
								port@0 {
									reg = <0>;
									ark_imx708_csi_in3: endpoint@6 {
										port-index = <3>;
										bus-width = <2>;
										remote-endpoint = <&ark_imx708_out3>;
									};
								};
								port@1 {
									reg = <1>;
									ark_imx708_csi_out3: endpoint@7 {
										remote-endpoint = <&ark_imx708_vi_in3>;
									};
								};
							};
						};
					};
				};
				i2c@3180000 {
					#address-cells = <1>;
					#size-cells = <0>;
					tca9546@70 {
						status = "okay";
						compatible = "nxp,pca9546";
						#address-cells = <1>;
						#size-cells = <0>;
						reg = <0x70>;
						i2c-parent = <&cam_i2c>;
						skip_mux_detect = "yes";
						force_bus_start = <CAMERA_I2C_MUX_BUS(0)>;
						i2c@0 {
							reg = <0>;
							#address-cells = <1>;
							#size-cells = <0>;
							i2c-mux,deselect-on-exit;
							status = "okay";

							/* Disable the baked-default IMX219 quad on the shared TCA9546 buses so only IMX708 is active. */
							ark_imx219_a@10 {
								status = "disabled";
							};

							ark_imx708_a@1a {
								status = "okay";
								reset-gpios = <&gpio CAM0_PWDN GPIO_ACTIVE_HIGH>;
								compatible = "sony,imx708";
								reg = <0x1a>;
								devnode = "video0";
								physical_w = "6.45";
								physical_h = "3.63";
								sensor_model = "imx708";
								use_sensor_mode_id = "true";

								mode0 { /* IMX708_MODE_4608x2592_14FPS */
									mclk_khz = "24000";
									num_lanes = "2";
									tegra_sinterface = "serial_a";
									lane_polarity = "6";
									phy_mode = "DPHY";
									discontinuous_clk = "yes";
									dpcm_enable = "false";
									cil_settletime = "0";
									active_w = "4608";
									active_h = "2592";
									mode_type = "bayer";
									pixel_phase = "rggb";
									csi_pixel_bit_depth = "10";
									readout_orientation = "90";
									line_length = "4808";
									inherent_gain = "1";
									pix_clk_hz = "297600000";
									gain_factor = "16";
									framerate_factor = "1000000";
									exposure_factor = "1000000";
									min_gain_val = "16";
									max_gain_val = "256";
									step_gain_val = "1";
									default_gain = "16";
									min_hdr_ratio = "1";
									max_hdr_ratio = "1";
									min_framerate = "2000000";
									max_framerate = "14000000";
									step_framerate = "1";
									default_framerate = "14000000";
									min_exp_time = "500";
									max_exp_time = "65487";
									step_exp_time = "1";
									default_exp_time = "1600";
									embedded_metadata_height = "4";
								};

								ports {
									#address-cells = <1>;
									#size-cells = <0>;
									port@0 {
										reg = <0>;
										ark_imx708_out0: endpoint {
											status = "okay";
											port-index = <0>;
											bus-width = <2>;
											remote-endpoint = <&ark_imx708_csi_in0>;
										};
									};
								};
							};
						};
						i2c@1 {
							reg = <1>;
							#address-cells = <1>;
							#size-cells = <0>;
							i2c-mux,deselect-on-exit;
							status = "okay";

							ark_imx219_b@10 {
								status = "disabled";
							};

							ark_imx708_b@1a {
								status = "okay";
								reset-gpios = <&gpio CAM1_PWDN GPIO_ACTIVE_HIGH>;
								compatible = "sony,imx708";
								reg = <0x1a>;
								devnode = "video1";
								physical_w = "6.45";
								physical_h = "3.63";
								sensor_model = "imx708";
								use_sensor_mode_id = "true";

								mode0 { /* IMX708_MODE_4608x2592_14FPS */
									mclk_khz = "24000";
									num_lanes = "2";
									tegra_sinterface = "serial_b";
									lane_polarity = "6";
									phy_mode = "DPHY";
									discontinuous_clk = "yes";
									dpcm_enable = "false";
									cil_settletime = "0";
									active_w = "4608";
									active_h = "2592";
									mode_type = "bayer";
									pixel_phase = "rggb";
									csi_pixel_bit_depth = "10";
									readout_orientation = "90";
									line_length = "4808";
									inherent_gain = "1";
									pix_clk_hz = "297600000";
									gain_factor = "16";
									framerate_factor = "1000000";
									exposure_factor = "1000000";
									min_gain_val = "16";
									max_gain_val = "256";
									step_gain_val = "1";
									default_gain = "16";
									min_hdr_ratio = "1";
									max_hdr_ratio = "1";
									min_framerate = "2000000";
									max_framerate = "14000000";
									step_framerate = "1";
									default_framerate = "14000000";
									min_exp_time = "500";
									max_exp_time = "65487";
									step_exp_time = "1";
									default_exp_time = "1600";
									embedded_metadata_height = "4";
								};

								ports {
									#address-cells = <1>;
									#size-cells = <0>;
									port@0 {
										reg = <0>;
										ark_imx708_out1: endpoint {
											status = "okay";
											port-index = <1>;
											bus-width = <2>;
											remote-endpoint = <&ark_imx708_csi_in1>;
										};
									};
								};
							};
						};
						i2c@2 {
							reg = <2>;
							#address-cells = <1>;
							#size-cells = <0>;
							i2c-mux,deselect-on-exit;
							status = "okay";

							ark_imx219_c@10 {
								status = "disabled";
							};

							ark_imx708_c@1a {
								status = "okay";
								reset-gpios = <&gpio CAM2_PWDN GPIO_ACTIVE_HIGH>;
								compatible = "sony,imx708";
								reg = <0x1a>;
								devnode = "video2";
								physical_w = "6.45";
								physical_h = "3.63";
								sensor_model = "imx708";
								use_sensor_mode_id = "true";

								mode0 { /* IMX708_MODE_4608x2592_14FPS */
									mclk_khz = "24000";
									num_lanes = "2";
									tegra_sinterface = "serial_c";
									lane_polarity = "0";
									phy_mode = "DPHY";
									discontinuous_clk = "yes";
									dpcm_enable = "false";
									cil_settletime = "0";
									active_w = "4608";
									active_h = "2592";
									mode_type = "bayer";
									pixel_phase = "rggb";
									csi_pixel_bit_depth = "10";
									readout_orientation = "90";
									line_length = "4808";
									inherent_gain = "1";
									pix_clk_hz = "297600000";
									gain_factor = "16";
									framerate_factor = "1000000";
									exposure_factor = "1000000";
									min_gain_val = "16";
									max_gain_val = "256";
									step_gain_val = "1";
									default_gain = "16";
									min_hdr_ratio = "1";
									max_hdr_ratio = "1";
									min_framerate = "2000000";
									max_framerate = "14000000";
									step_framerate = "1";
									default_framerate = "14000000";
									min_exp_time = "500";
									max_exp_time = "65487";
									step_exp_time = "1";
									default_exp_time = "1600";
									embedded_metadata_height = "4";
								};

								ports {
									#address-cells = <1>;
									#size-cells = <0>;
									port@0 {
										reg = <0>;
										ark_imx708_out2: endpoint {
											status = "okay";
											port-index = <2>;
											bus-width = <2>;
											remote-endpoint = <&ark_imx708_csi_in2>;
										};
									};
								};
							};
						};
						i2c@3 {
							reg = <3>;
							#address-cells = <1>;
							#size-cells = <0>;
							i2c-mux,deselect-on-exit;
							status = "okay";

							ark_imx219_d@10 {
								status = "disabled";
							};

							ark_imx708_d@1a {
								status = "okay";
								reset-gpios = <&gpio_aon CAM3_PWDN GPIO_ACTIVE_HIGH>;
								compatible = "sony,imx708";
								reg = <0x1a>;
								devnode = "video3";
								physical_w = "6.45";
								physical_h = "3.63";
								sensor_model = "imx708";
								use_sensor_mode_id = "true";

								mode0 { /* IMX708_MODE_4608x2592_14FPS */
									mclk_khz = "24000";
									num_lanes = "2";
									tegra_sinterface = "serial_d";
									lane_polarity = "0";
									phy_mode = "DPHY";
									discontinuous_clk = "yes";
									dpcm_enable = "false";
									cil_settletime = "0";
									active_w = "4608";
									active_h = "2592";
									mode_type = "bayer";
									pixel_phase = "rggb";
									csi_pixel_bit_depth = "10";
									readout_orientation = "90";
									line_length = "4808";
									inherent_gain = "1";
									pix_clk_hz = "297600000";
									gain_factor = "16";
									framerate_factor = "1000000";
									exposure_factor = "1000000";
									min_gain_val = "16";
									max_gain_val = "256";
									step_gain_val = "1";
									default_gain = "16";
									min_hdr_ratio = "1";
									max_hdr_ratio = "1";
									min_framerate = "2000000";
									max_framerate = "14000000";
									step_framerate = "1";
									default_framerate = "14000000";
									min_exp_time = "500";
									max_exp_time = "65487";
									step_exp_time = "1";
									default_exp_time = "1600";
									embedded_metadata_height = "4";
								};

								ports {
									#address-cells = <1>;
									#size-cells = <0>;
									port@0 {
										reg = <0>;
										ark_imx708_out3: endpoint {
											status = "okay";
											port-index = <3>;
											bus-width = <2>;
											remote-endpoint = <&ark_imx708_csi_in3>;
										};
									};
								};
							};
						};
					};
				};
				gpio@2200000 {
					camera-control-output-high {
						gpios = <CAM0_PWDN 1 CAM1_PWDN 1 CAM2_PWDN 1 CAM3_PWDN 1>;
						label = "cam0-pwdn", "cam1-pwdn", "cam2-pwdn", "cam3-pwdn";
					};
				};
			};
		};
	};
};
