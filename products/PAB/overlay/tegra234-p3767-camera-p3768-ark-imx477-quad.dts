//
// IMX477 (Raspberry Pi HQ / Arducam 12MP) 4-camera overlay for the ARK p3768
// carrier (4x2-lane CSI). Carrier wiring (TCA9546 mux, per-port CAM reset and
// lane polarity) mirrors the IMX219/IMX708 quads; sensor nodes and modes come
// from the stock ridgerun,imx477 driver. Two 10-bit modes per camera:
// 3840x2160 @ 30 fps and 1920x1080 @ 60 fps.

/dts-v1/;
/plugin/;

#define CAM0_PWDN	TEGRA234_MAIN_GPIO(H, 6)
#define CAM1_PWDN	TEGRA234_MAIN_GPIO(AC, 0)
#define CAM2_PWDN	TEGRA234_MAIN_GPIO(Y, 4)
#define CAM3_PWDN	TEGRA234_AON_GPIO(CC, 3)
#define CAMERA_I2C_MUX_BUS(x) (0x1E + x)

#include <dt-bindings/tegra234-p3767-0000-common.h>

/ {
	overlay-name = "Camera ARK IMX477 Quad";
	jetson-header-name = "Jetson 22pin CSI Connector";
	compatible = JETSON_COMPATIBLE_P3768;

	fragment-camera@0 {
		target-path = "/";
		__overlay__ {
			tegra-capture-vi {
				num-channels = <4>;
				ports {
					#address-cells = <1>;
					#size-cells = <0>;
					port@0 {
						reg = <0>;
						ark_imx477_vi_in0: endpoint {
							port-index = <0>;
							bus-width = <2>;
							remote-endpoint = <&ark_imx477_csi_out0>;
						};
					};
					port@1 {
						reg = <1>;
						ark_imx477_vi_in1: endpoint {
							port-index = <1>;
							bus-width = <2>;
							remote-endpoint = <&ark_imx477_csi_out1>;
						};
					};
					port@2 {
						reg = <2>;
						ark_imx477_vi_in2: endpoint {
							port-index = <2>;
							bus-width = <2>;
							remote-endpoint = <&ark_imx477_csi_out2>;
						};
					};
					port@3 {
						reg = <3>;
						ark_imx477_vi_in3: endpoint {
							port-index = <3>;
							bus-width = <2>;
							remote-endpoint = <&ark_imx477_csi_out3>;
						};
					};
				};
			};
			tegra-camera-platform {
				compatible = "nvidia, tegra-camera-platform";
				num_csi_lanes = <8>;
				max_lane_speed = <1500000>;	/* imx477 10-bit/2-lane at 300 MHz pix clk = 1.5 Gbps per lane */
				min_bits_per_pixel = <10>;
				vi_peak_byte_per_pixel = <2>;
				vi_bw_margin_pct = <25>;
				max_pixel_rate = <240000>;
				isp_peak_byte_per_pixel = <5>;
				isp_bw_margin_pct = <25>;
				modules {
					module0 {
						badge = "ark_imx477_bottomleft_IMX477";
						position = "bottomleft";
						orientation = "0";
						drivernode0 {
							pcl_id = "v4l2_sensor";
							sysfs-device-tree = "/sys/firmware/devicetree/base/bus@0/i2c@3180000/tca9546@70/i2c@0/ark_imx477_a@1a";
						};
					};
					module1 {
						badge = "ark_imx477_bottomright_IMX477";
						position = "bottomright";
						orientation = "1";
						drivernode0 {
							pcl_id = "v4l2_sensor";
							sysfs-device-tree = "/sys/firmware/devicetree/base/bus@0/i2c@3180000/tca9546@70/i2c@1/ark_imx477_b@1a";
						};
					};
					module2 {
						badge = "ark_imx477_centerleft_IMX477";
						position = "centerleft";
						orientation = "2";
						drivernode0 {
							pcl_id = "v4l2_sensor";
							sysfs-device-tree = "/sys/firmware/devicetree/base/bus@0/i2c@3180000/tca9546@70/i2c@2/ark_imx477_c@1a";
						};
					};
					module3 {
						badge = "ark_imx477_centerright_IMX477";
						position = "centerright";
						orientation = "3";
						drivernode0 {
							pcl_id = "v4l2_sensor";
							sysfs-device-tree = "/sys/firmware/devicetree/base/bus@0/i2c@3180000/tca9546@70/i2c@3/ark_imx477_d@1a";
						};
					};
				};
			};
			bus@0 {
				host1x@13e00000 {
					nvcsi@15a00000 {
						num-channels = <4>;
						#address-cells = <1>;
						#size-cells = <0>;
						status = "okay";
						channel@0 {
							reg = <0>;
							ports {
								#address-cells = <1>;
								#size-cells = <0>;
								port@0 {
									reg = <0>;
									ark_imx477_csi_in0: endpoint@0 {
										port-index = <0>;
										bus-width = <2>;
										remote-endpoint = <&ark_imx477_out0>;
									};
								};
								port@1 {
									reg = <1>;
									ark_imx477_csi_out0: endpoint@1 {
										remote-endpoint = <&ark_imx477_vi_in0>;
									};
								};
							};
						};
						channel@1 {
							reg = <1>;
							ports {
								#address-cells = <1>;
								#size-cells = <0>;
								port@0 {
									reg = <0>;
									ark_imx477_csi_in1: endpoint@2 {
										port-index = <1>;
										bus-width = <2>;
										remote-endpoint = <&ark_imx477_out1>;
									};
								};
								port@1 {
									reg = <1>;
									ark_imx477_csi_out1: endpoint@3 {
										remote-endpoint = <&ark_imx477_vi_in1>;
									};
								};
							};
						};
						channel@2 {
							reg = <2>;
							ports {
								#address-cells = <1>;
								#size-cells = <0>;
								port@0 {
									reg = <0>;
									ark_imx477_csi_in2: endpoint@4 {
										port-index = <2>;
										bus-width = <2>;
										remote-endpoint = <&ark_imx477_out2>;
									};
								};
								port@1 {
									reg = <1>;
									ark_imx477_csi_out2: endpoint@5 {
										remote-endpoint = <&ark_imx477_vi_in2>;
									};
								};
							};
						};
						channel@3 {
							reg = <3>;
							ports {
								#address-cells = <1>;
								#size-cells = <0>;
								port@0 {
									reg = <0>;
									ark_imx477_csi_in3: endpoint@6 {
										port-index = <3>;
										bus-width = <2>;
										remote-endpoint = <&ark_imx477_out3>;
									};
								};
								port@1 {
									reg = <1>;
									ark_imx477_csi_out3: endpoint@7 {
										remote-endpoint = <&ark_imx477_vi_in3>;
									};
								};
							};
						};
					};
				};
				i2c@3180000 {
					#address-cells = <1>;
					#size-cells = <0>;
					tca9546@70 {
						status = "okay";
						compatible = "nxp,pca9546";
						#address-cells = <1>;
						#size-cells = <0>;
						reg = <0x70>;
						i2c-parent = <&cam_i2c>;
						skip_mux_detect = "yes";
						force_bus_start = <CAMERA_I2C_MUX_BUS(0)>;
						i2c@0 {
							reg = <0>;
							#address-cells = <1>;
							#size-cells = <0>;
							i2c-mux,deselect-on-exit;
							status = "okay";

							/* Disable the baked-default IMX219 quad on the shared TCA9546 buses so only IMX477 is active. */
							ark_imx219_a@10 {
								status = "disabled";
							};

							ark_imx477_a@1a {
								status = "okay";
								reset-gpios = <&gpio CAM0_PWDN GPIO_ACTIVE_HIGH>;
								compatible = "ridgerun,imx477";
								reg = <0x1a>;
								devnode = "video0";
								physical_w = "3.680";
								physical_h = "2.760";
								sensor_model = "imx477";
								use_sensor_mode_id = "true";

								mode0 { /* IMX477_MODE_3840x2160 */
									mclk_khz = "24000";
									num_lanes = "2";
									tegra_sinterface = "serial_a";
									phy_mode = "DPHY";
									discontinuous_clk = "no";
									dpcm_enable = "false";
									cil_settletime = "0";
									lane_polarity = "6";
									active_w = "3840";
									active_h = "2160";
									mode_type = "bayer";
									pixel_phase = "rggb";
									csi_pixel_bit_depth = "10";
									readout_orientation = "90";
									line_length = "11200";
									inherent_gain = "1";
									mclk_multiplier = "80";
									pix_clk_hz = "300000000";
									gain_factor = "16";
									framerate_factor = "1000000";
									exposure_factor = "1000000";
									min_gain_val = "16"; /* 1.00x */
									max_gain_val = "356"; /* 22x */
									step_gain_val = "1";
									default_gain = "16"; /* 1.00x */
									min_hdr_ratio = "1";
									max_hdr_ratio = "1";
									min_framerate = "2000000"; /* 2.0 fps */
									max_framerate = "30000000"; /* 30.0 fps */
									step_framerate = "1";
									default_framerate = "30000000"; /* 30.0 fps */
									min_exp_time = "13"; /* us */
									max_exp_time = "683709"; /* us */
									step_exp_time = "1";
									default_exp_time = "2495"; /* us */
									embedded_metadata_height = "2";
								};
								mode1 { /* IMX477_MODE_1920X1080 */
									mclk_khz = "24000";
									num_lanes = "2";
									tegra_sinterface = "serial_a";
									phy_mode = "DPHY";
									discontinuous_clk = "no";
									dpcm_enable = "false";
									cil_settletime = "0";
									lane_polarity = "6";
									active_w = "1920";
									active_h = "1080";
									mode_type = "bayer";
									pixel_phase = "rggb";
									csi_pixel_bit_depth = "10";
									readout_orientation = "90";
									line_length = "7000";
									inherent_gain = "1";
									mclk_multiplier = "80";
									pix_clk_hz = "300000000";
									gain_factor = "16";
									framerate_factor = "1000000";
									exposure_factor = "1000000";
									min_gain_val = "16"; /* 1.00x */
									max_gain_val = "356"; /* 22x */
									step_gain_val = "1";
									default_gain = "16"; /* 1.00x */
									min_hdr_ratio = "1";
									max_hdr_ratio = "1";
									min_framerate = "2000000"; /* 2.0 fps */
									max_framerate = "60000000"; /* 60.0 fps */
									step_framerate = "1";
									default_framerate = "60000000"; /* 60.0 fps */
									min_exp_time = "13"; /* us */
									max_exp_time = "683709"; /* us */
									step_exp_time = "1";
									default_exp_time = "2495"; /* us */
									embedded_metadata_height = "2";
								};

								ports {
									#address-cells = <1>;
									#size-cells = <0>;
									port@0 {
										reg = <0>;
										ark_imx477_out0: endpoint {
											status = "okay";
											port-index = <0>;
											bus-width = <2>;
											remote-endpoint = <&ark_imx477_csi_in0>;
										};
									};
								};
							};
						};
						i2c@1 {
							reg = <1>;
							#address-cells = <1>;
							#size-cells = <0>;
							i2c-mux,deselect-on-exit;
							status = "okay";

							ark_imx219_b@10 {
								status = "disabled";
							};

							ark_imx477_b@1a {
								status = "okay";
								reset-gpios = <&gpio CAM1_PWDN GPIO_ACTIVE_HIGH>;
								compatible = "ridgerun,imx477";
								reg = <0x1a>;
								devnode = "video1";
								physical_w = "3.680";
								physical_h = "2.760";
								sensor_model = "imx477";
								use_sensor_mode_id = "true";

								mode0 { /* IMX477_MODE_3840x2160 */
									mclk_khz = "24000";
									num_lanes = "2";
									tegra_sinterface = "serial_b";
									phy_mode = "DPHY";
									discontinuous_clk = "no";
									dpcm_enable = "false";
									cil_settletime = "0";
									lane_polarity = "6";
									active_w = "3840";
									active_h = "2160";
									mode_type = "bayer";
									pixel_phase = "rggb";
									csi_pixel_bit_depth = "10";
									readout_orientation = "90";
									line_length = "11200";
									inherent_gain = "1";
									mclk_multiplier = "80";
									pix_clk_hz = "300000000";
									gain_factor = "16";
									framerate_factor = "1000000";
									exposure_factor = "1000000";
									min_gain_val = "16"; /* 1.00x */
									max_gain_val = "356"; /* 22x */
									step_gain_val = "1";
									default_gain = "16"; /* 1.00x */
									min_hdr_ratio = "1";
									max_hdr_ratio = "1";
									min_framerate = "2000000"; /* 2.0 fps */
									max_framerate = "30000000"; /* 30.0 fps */
									step_framerate = "1";
									default_framerate = "30000000"; /* 30.0 fps */
									min_exp_time = "13"; /* us */
									max_exp_time = "683709"; /* us */
									step_exp_time = "1";
									default_exp_time = "2495"; /* us */
									embedded_metadata_height = "2";
								};
								mode1 { /* IMX477_MODE_1920X1080 */
									mclk_khz = "24000";
									num_lanes = "2";
									tegra_sinterface = "serial_b";
									phy_mode = "DPHY";
									discontinuous_clk = "no";
									dpcm_enable = "false";
									cil_settletime = "0";
									lane_polarity = "6";
									active_w = "1920";
									active_h = "1080";
									mode_type = "bayer";
									pixel_phase = "rggb";
									csi_pixel_bit_depth = "10";
									readout_orientation = "90";
									line_length = "7000";
									inherent_gain = "1";
									mclk_multiplier = "80";
									pix_clk_hz = "300000000";
									gain_factor = "16";
									framerate_factor = "1000000";
									exposure_factor = "1000000";
									min_gain_val = "16"; /* 1.00x */
									max_gain_val = "356"; /* 22x */
									step_gain_val = "1";
									default_gain = "16"; /* 1.00x */
									min_hdr_ratio = "1";
									max_hdr_ratio = "1";
									min_framerate = "2000000"; /* 2.0 fps */
									max_framerate = "60000000"; /* 60.0 fps */
									step_framerate = "1";
									default_framerate = "60000000"; /* 60.0 fps */
									min_exp_time = "13"; /* us */
									max_exp_time = "683709"; /* us */
									step_exp_time = "1";
									default_exp_time = "2495"; /* us */
									embedded_metadata_height = "2";
								};

								ports {
									#address-cells = <1>;
									#size-cells = <0>;
									port@0 {
										reg = <0>;
										ark_imx477_out1: endpoint {
											status = "okay";
											port-index = <1>;
											bus-width = <2>;
											remote-endpoint = <&ark_imx477_csi_in1>;
										};
									};
								};
							};
						};
						i2c@2 {
							reg = <2>;
							#address-cells = <1>;
							#size-cells = <0>;
							i2c-mux,deselect-on-exit;
							status = "okay";

							ark_imx219_c@10 {
								status = "disabled";
							};

							ark_imx477_c@1a {
								status = "okay";
								reset-gpios = <&gpio CAM2_PWDN GPIO_ACTIVE_HIGH>;
								compatible = "ridgerun,imx477";
								reg = <0x1a>;
								devnode = "video2";
								physical_w = "3.680";
								physical_h = "2.760";
								sensor_model = "imx477";
								use_sensor_mode_id = "true";

								mode0 { /* IMX477_MODE_3840x2160 */
									mclk_khz = "24000";
									num_lanes = "2";
									tegra_sinterface = "serial_c";
									phy_mode = "DPHY";
									discontinuous_clk = "no";
									dpcm_enable = "false";
									cil_settletime = "0";
									lane_polarity = "0";
									active_w = "3840";
									active_h = "2160";
									mode_type = "bayer";
									pixel_phase = "rggb";
									csi_pixel_bit_depth = "10";
									readout_orientation = "90";
									line_length = "11200";
									inherent_gain = "1";
									mclk_multiplier = "80";
									pix_clk_hz = "300000000";
									gain_factor = "16";
									framerate_factor = "1000000";
									exposure_factor = "1000000";
									min_gain_val = "16"; /* 1.00x */
									max_gain_val = "356"; /* 22x */
									step_gain_val = "1";
									default_gain = "16"; /* 1.00x */
									min_hdr_ratio = "1";
									max_hdr_ratio = "1";
									min_framerate = "2000000"; /* 2.0 fps */
									max_framerate = "30000000"; /* 30.0 fps */
									step_framerate = "1";
									default_framerate = "30000000"; /* 30.0 fps */
									min_exp_time = "13"; /* us */
									max_exp_time = "683709"; /* us */
									step_exp_time = "1";
									default_exp_time = "2495"; /* us */
									embedded_metadata_height = "2";
								};
								mode1 { /* IMX477_MODE_1920X1080 */
									mclk_khz = "24000";
									num_lanes = "2";
									tegra_sinterface = "serial_c";
									phy_mode = "DPHY";
									discontinuous_clk = "no";
									dpcm_enable = "false";
									cil_settletime = "0";
									lane_polarity = "0";
									active_w = "1920";
									active_h = "1080";
									mode_type = "bayer";
									pixel_phase = "rggb";
									csi_pixel_bit_depth = "10";
									readout_orientation = "90";
									line_length = "7000";
									inherent_gain = "1";
									mclk_multiplier = "80";
									pix_clk_hz = "300000000";
									gain_factor = "16";
									framerate_factor = "1000000";
									exposure_factor = "1000000";
									min_gain_val = "16"; /* 1.00x */
									max_gain_val = "356"; /* 22x */
									step_gain_val = "1";
									default_gain = "16"; /* 1.00x */
									min_hdr_ratio = "1";
									max_hdr_ratio = "1";
									min_framerate = "2000000"; /* 2.0 fps */
									max_framerate = "60000000"; /* 60.0 fps */
									step_framerate = "1";
									default_framerate = "60000000"; /* 60.0 fps */
									min_exp_time = "13"; /* us */
									max_exp_time = "683709"; /* us */
									step_exp_time = "1";
									default_exp_time = "2495"; /* us */
									embedded_metadata_height = "2";
								};

								ports {
									#address-cells = <1>;
									#size-cells = <0>;
									port@0 {
										reg = <0>;
										ark_imx477_out2: endpoint {
											status = "okay";
											port-index = <2>;
											bus-width = <2>;
											remote-endpoint = <&ark_imx477_csi_in2>;
										};
									};
								};
							};
						};
						i2c@3 {
							reg = <3>;
							#address-cells = <1>;
							#size-cells = <0>;
							i2c-mux,deselect-on-exit;
							status = "okay";

							ark_imx219_d@10 {
								status = "disabled";
							};

							ark_imx477_d@1a {
								status = "okay";
								reset-gpios = <&gpio_aon CAM3_PWDN GPIO_ACTIVE_HIGH>;
								compatible = "ridgerun,imx477";
								reg = <0x1a>;
								devnode = "video3";
								physical_w = "3.680";
								physical_h = "2.760";
								sensor_model = "imx477";
								use_sensor_mode_id = "true";

								mode0 { /* IMX477_MODE_3840x2160 */
									mclk_khz = "24000";
									num_lanes = "2";
									tegra_sinterface = "serial_d";
									phy_mode = "DPHY";
									discontinuous_clk = "no";
									dpcm_enable = "false";
									cil_settletime = "0";
									lane_polarity = "0";
									active_w = "3840";
									active_h = "2160";
									mode_type = "bayer";
									pixel_phase = "rggb";
									csi_pixel_bit_depth = "10";
									readout_orientation = "90";
									line_length = "11200";
									inherent_gain = "1";
									mclk_multiplier = "80";
									pix_clk_hz = "300000000";
									gain_factor = "16";
									framerate_factor = "1000000";
									exposure_factor = "1000000";
									min_gain_val = "16"; /* 1.00x */
									max_gain_val = "356"; /* 22x */
									step_gain_val = "1";
									default_gain = "16"; /* 1.00x */
									min_hdr_ratio = "1";
									max_hdr_ratio = "1";
									min_framerate = "2000000"; /* 2.0 fps */
									max_framerate = "30000000"; /* 30.0 fps */
									step_framerate = "1";
									default_framerate = "30000000"; /* 30.0 fps */
									min_exp_time = "13"; /* us */
									max_exp_time = "683709"; /* us */
									step_exp_time = "1";
									default_exp_time = "2495"; /* us */
									embedded_metadata_height = "2";
								};
								mode1 { /* IMX477_MODE_1920X1080 */
									mclk_khz = "24000";
									num_lanes = "2";
									tegra_sinterface = "serial_d";
									phy_mode = "DPHY";
									discontinuous_clk = "no";
									dpcm_enable = "false";
									cil_settletime = "0";
									lane_polarity = "0";
									active_w = "1920";
									active_h = "1080";
									mode_type = "bayer";
									pixel_phase = "rggb";
									csi_pixel_bit_depth = "10";
									readout_orientation = "90";
									line_length = "7000";
									inherent_gain = "1";
									mclk_multiplier = "80";
									pix_clk_hz = "300000000";
									gain_factor = "16";
									framerate_factor = "1000000";
									exposure_factor = "1000000";
									min_gain_val = "16"; /* 1.00x */
									max_gain_val = "356"; /* 22x */
									step_gain_val = "1";
									default_gain = "16"; /* 1.00x */
									min_hdr_ratio = "1";
									max_hdr_ratio = "1";
									min_framerate = "2000000"; /* 2.0 fps */
									max_framerate = "60000000"; /* 60.0 fps */
									step_framerate = "1";
									default_framerate = "60000000"; /* 60.0 fps */
									min_exp_time = "13"; /* us */
									max_exp_time = "683709"; /* us */
									step_exp_time = "1";
									default_exp_time = "2495"; /* us */
									embedded_metadata_height = "2";
								};

								ports {
									#address-cells = <1>;
									#size-cells = <0>;
									port@0 {
										reg = <0>;
										ark_imx477_out3: endpoint {
											status = "okay";
											port-index = <3>;
											bus-width = <2>;
											remote-endpoint = <&ark_imx477_csi_in3>;
										};
									};
								};
							};
						};
					};
				};
				gpio@2200000 {
					camera-control-output-high {
						gpios = <CAM0_PWDN 1 CAM1_PWDN 1 CAM2_PWDN 1 CAM3_PWDN 1>;
						label = "cam0-pwdn", "cam1-pwdn", "cam2-pwdn", "cam3-pwdn";
					};
				};
			};
		};
	};
};
