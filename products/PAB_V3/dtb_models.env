# Per-SKU device-tree model strings, stamped onto the stock p3768 DTS by build.sh.
# Format: <p3767 SKU>=<model>. The matching -nv-super DTB gets " Super" appended.
# SKUs not listed keep NVIDIA's stock model.
0000=NVIDIA Jetson Orin NX 16GB ARK PAB_V3 Jetson Carrier
0001=NVIDIA Jetson Orin NX 8GB ARK PAB_V3 Jetson Carrier
0003=NVIDIA Jetson Orin Nano 8GB ARK PAB_V3 Jetson Carrier
0004=NVIDIA Jetson Orin Nano 4GB ARK PAB_V3 Jetson Carrier
0005=NVIDIA Jetson Orin Nano 8GB ARK PAB_V3 Jetson Carrier
