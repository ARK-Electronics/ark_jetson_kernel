# Single source of truth for every pinned version and download URL in this repo.
# - To bump the BSP, change EXPECTED_BSP_RELEASE / EXPECTED_BSP_REVISION below.
# - All three L4T URLs derive from these.
# - The toolchain URL is pinned independently (NVIDIA reuses the r38 x-tools package for r39).

EXPECTED_BSP_RELEASE="R39"
EXPECTED_BSP_REVISION="2.0"

# Jetpack marketing version. Update this when bumping the BSP.
JETPACK_VERSION="7.2"

# NVIDIA URL conventions — derived from the constants above:
#   release path: r{release_lower}_release_v{revision}    e.g. r39_release_v2.0
#   package tag:  {EXPECTED_BSP_RELEASE}.{revision}       e.g. R39.2.0 (capital R for R39+)
#   cache tag:    r{release_lower}.{revision}             e.g. r39.2.0
_release_lc=$(echo "$EXPECTED_BSP_RELEASE" | tr '[:upper:]' '[:lower:]')
_release_path="${_release_lc}_release_v${EXPECTED_BSP_REVISION}"
_file_tag="${EXPECTED_BSP_RELEASE}.${EXPECTED_BSP_REVISION}"
_cache_tag="${_release_lc}.${EXPECTED_BSP_REVISION}"

# https://developer.nvidia.com/embedded/jetson-linux-archive
BSP_URL="https://developer.nvidia.com/downloads/embedded/l4t/${_release_path}/release/Jetson_Linux_${_file_tag}_aarch64.tbz2"
ROOT_FS_URL="https://developer.nvidia.com/downloads/embedded/l4t/${_release_path}/release/Tegra_Linux_Sample-Root-Filesystem_${_file_tag}_aarch64.tbz2"
PUBLIC_SOURCES_URL="https://developer.nvidia.com/downloads/embedded/l4t/${_release_path}/sources/public_sources.tbz2"

# Cache public_sources.tbz2 locally under a version-stamped name so a BSP bump is a cache miss.
PUBLIC_SOURCES_FILE="public_sources_${_cache_tag}.tbz2"

# Crosstool-NG gcc 13.2 aarch64 toolchain (shipped under the r38 path; r39 reuses it).
# Extracts to $HOME/l4t-gcc/x-tools/aarch64-none-linux-gnu/
TOOLCHAIN_URL="https://developer.nvidia.com/downloads/embedded/l4t/r38_release_v2.0/release/x-tools.tbz2"
# Relative to $HOME/l4t-gcc — used as CROSS_COMPILE prefix and as the "already extracted" marker.
TOOLCHAIN_CROSS_PREFIX="x-tools/aarch64-none-linux-gnu/bin/aarch64-none-linux-gnu-"

# Kernel source dir under Linux_for_Tegra/source/kernel/ and the OOT kernel_name export.
KERNEL_SRC_DIR="kernel-noble"
KERNEL_NAME="noble"

unset _release_lc _release_path _file_tag _cache_tag

# ARK-OS payload is installed only with --provision
# JETSON_STATS_VERSION must match the canonical pin in ARK-OS packaging/versions.env
# (MAVSDK needs no pin here: it is bundled inside the ark-os deb since ARK-OS#75)
#
ARK_OS_VERSION="1.1.0"
JETSON_STATS_VERSION="4.3.2"   # jtop daemon + client, installed system-wide via pip

# nvidia-l4t-gstreamer: Tegra GStreamer plugins (nvarguscamerasrc, nvvidconv, nvv4l2*)
# for CSI camera pipelines. Not in the BSP deb set apply_binaries installs (it lives in
# the repo's `common` pool), so --provision bakes it in. Pin matches the BSP build stamp;
# bump it with the BSP.
NV_GSTREAMER_VERSION="39.2.0-20260601141651"
