# Single source of truth for every pinned version and download URL in this repo —
# the BSP / toolchain (used by setup.sh and scripts/check_bsp.sh) and the ARK-OS
# payload (used by provision.sh). Mirrors ark_pi_image/versions.env.
#
# To bump the BSP, change EXPECTED_BSP_RELEASE / EXPECTED_BSP_REVISION below.
# All three L4T URLs derive from these. The toolchain URL is pinned
# independently because bootlin gcc tracks its own release cadence.

EXPECTED_BSP_RELEASE="R36"
EXPECTED_BSP_REVISION="5.0"

# Jetpack marketing version — not derivable from L4T version numbers.
# Update this when bumping the BSP.
JETPACK_VERSION="6.2.2"

# NVIDIA URL conventions — derived from the constants above:
#   release path: r{release_lower}_release_v{revision}    e.g. r36_release_v5.0
#   archive tag:  r{release_lower}.{revision}             e.g. r36.5.0
_release_lc=$(echo "$EXPECTED_BSP_RELEASE" | tr '[:upper:]' '[:lower:]')
_release_path="${_release_lc}_release_v${EXPECTED_BSP_REVISION}"
_release_tag="${_release_lc}.${EXPECTED_BSP_REVISION}"

# https://developer.nvidia.com/embedded/jetson-linux-archive
BSP_URL="https://developer.nvidia.com/downloads/embedded/l4t/${_release_path}/release/Jetson_Linux_${_release_tag}_aarch64.tbz2"
ROOT_FS_URL="https://developer.nvidia.com/downloads/embedded/l4t/${_release_path}/release/Tegra_Linux_Sample-Root-Filesystem_${_release_tag}_aarch64.tbz2"
PUBLIC_SOURCES_URL="https://developer.nvidia.com/downloads/embedded/l4t/${_release_path}/sources/public_sources.tbz2"

# NVIDIA serves public_sources.tbz2 with a constant filename across releases, unlike
# the version-stamped BSP/rootfs tarballs. Cache it locally under a version-stamped
# name so a BSP bump is a cache miss (downloads/ persists across bumps locally) rather
# than a silent reuse of the previous release's kernel sources.
PUBLIC_SOURCES_FILE="public_sources_${_release_tag}.tbz2"

# Bootlin gcc cross-toolchain — pinned to its own r36 release, independent of the L4T patch revision.
TOOLCHAIN_URL="https://developer.nvidia.com/downloads/embedded/l4t/r36_release_v3.0/toolchain/aarch64--glibc--stable-2022.08-1.tar.bz2"

unset _release_lc _release_path _release_tag

# --- ARK-OS payload (installed by provision.sh, only with --provision) -------------
# MAVSDK_VERSION and JETSON_STATS_VERSION must match the canonical pins in ARK-OS
# packaging/versions.env — this repo has no ARK-OS checkout at build time, so they're
# duplicated here; keep them in sync there.
#
# ARK_OS_VERSION points at a CI-artifact build — untagged ARK-OS CI builds are
# versioned 0.0.0-<sha8> and the matching deb is cached in downloads/. Bump to the
# released version (e.g. 1.0.0) once ARK-OS PR #68 merges and a GitHub release exists.
ARK_OS_VERSION="0.0.0-0af28d74"
MAVSDK_VERSION="3.17.1"
JETSON_STATS_VERSION="4.3.2"   # jtop daemon + client, installed system-wide via pip
